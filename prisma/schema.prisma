// AI CareerKit — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  headline  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes Resume[]

  @@map("users")
}

model Resume {
  id       String  @id @default(cuid())
  title    String
  fullName String?
  email    String?
  phone    String?
  location String?
  website  String?
  summary  String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  experiences WorkExperience[]
  educations  Education[]
  skills      Skill[]
  projects    Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resumes")
}

model WorkExperience {
  id        String   @id @default(cuid())
  role      String
  company   String
  startDate String
  endDate   String?
  current   Boolean  @default(false)
  bullets   String[]

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("work_experiences")
}

model Education {
  id        String  @id @default(cuid())
  school    String
  degree    String
  field     String?
  startYear String?
  endYear   String?

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Skill {
  id   String @id @default(cuid())
  name String

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String?
  tech        String[]

  resumeId String?
  resume   Resume? @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("projects")
}
