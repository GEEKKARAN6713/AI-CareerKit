// AI CareerKit — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  headline  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes       Resume[]
  portfolio     Portfolio?
  aiGenerations AiGeneration[]

  @@map("users")
}

model Resume {
  id       String  @id @default(cuid())
  title    String
  fullName String?
  email    String?
  phone    String?
  location String?
  website  String?
  summary  String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  experiences WorkExperience[]
  educations  Education[]
  skills      Skill[]
  projects    Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resumes")
}

model WorkExperience {
  id        String   @id @default(cuid())
  role      String
  company   String
  startDate String
  endDate   String?
  current   Boolean  @default(false)
  bullets   String[]

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("work_experiences")
}

model Education {
  id        String  @id @default(cuid())
  school    String
  degree    String
  field     String?
  startYear String?
  endYear   String?

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Skill {
  id   String @id @default(cuid())
  name String

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String?
  tech        String[]

  resumeId String?
  resume   Resume? @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("projects")
}

model AiGeneration {
  id           String   @id @default(cuid())
  type         String // BULLETS | SUMMARY | ATS_SCORE | LINKEDIN_HEADLINE | LINKEDIN_ABOUT | CAREER_SUGGESTIONS
  input        String
  output       String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("ai_generations")
}

model Portfolio {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  tagline     String?
  bio         String?
  skills      String[]
  github      String?
  linkedin    String?
  twitter     String?
  websiteUrl  String?
  theme       String   @default("minimal") // minimal | gradient | midnight
  published   Boolean  @default(true)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolios")
}
